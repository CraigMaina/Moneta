{
  "name": "moneta",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.config.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.config.{ts,js}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parser": "vitest run src/parser --passWithNoTests",
    "test:db": "supabase test db",
    "test:rls": "node supabase/tests/run-pgtap.mjs",
    "test:coverage": "vitest run --coverage",
    "gen:types": "supabase gen types typescript --project-id passrudtrwgqmimtldtt --schema public > src/lib/database.types.ts",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@fontsource/bricolage-grotesque": "^5.2.10",
